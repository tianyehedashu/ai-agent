# 服务级前缀（默认 /ai-agent；设为空字符串则部署在站点根路径）
VITE_APP_ROOT=/ai-agent

# 认证模式：local（本地邮箱密码 + JWT，默认/开发）| sso（giikin 单点登录）
# sso 模式下身份由 HiGress(giikin-auth-bridge) 注入 Header，或 guard_token Cookie + Redis 回退
VITE_AUTH_MODE=sso

# SSO 登录入口（sso 模式必填）：IAM company_sso binding API（同域）
# buildSsoLoginUrl 会追加 callbackOrigin（含 VITE_APP_ROOT）与 redirect
VITE_SSO_LOGIN_URL=http://gateway.giimallai.com/api/auth/binding/company_sso?tenantId=000000&domain=admin
