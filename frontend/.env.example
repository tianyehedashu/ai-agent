# 服务级前缀（默认 /ai-agent；设为空字符串则部署在站点根路径）
VITE_APP_ROOT=/ai-agent

# 认证模式：local（本地邮箱密码 + JWT，默认/开发）| sso（giikin 单点登录）| hybrid（双通道）
# sso/hybrid 模式下身份由 HiGress(giikin-auth-bridge) 注入 Header，或 guard_token Cookie + Redis 回退
# hybrid 模式：Bearer JWT 优先，无 Bearer 才走网关 Header；登录页同时展示 SSO 按钮与邮箱表单
VITE_AUTH_MODE=sso

# SSO 登录入口（sso 模式必填）：IAM company_sso binding API（同域）
# buildSsoLoginUrl 会追加 callbackOrigin（含 VITE_APP_ROOT）与 redirect
VITE_SSO_LOGIN_URL=https://gateway.giimallai.com/api/auth/binding/company_sso?tenantId=000000&domain=admin

# SSO 登出（可选；默认同域 /api/auth/logout，须带 Cookie 才能清除 guard_token）
# VITE_SSO_LOGOUT_URL=https://gateway.giimallai.com/api/auth/logout
