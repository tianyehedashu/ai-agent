# 服务级前缀（默认 /ai-agent；设为空字符串则部署在站点根路径）
VITE_APP_ROOT=/ai-agent

# 认证模式：local（本地邮箱密码 + JWT，默认/开发）| sso（giikin 单点登录）
# sso 模式下身份由 HiGress(giikin-auth-bridge) 经 guard_token Cookie 注入，前端无本地 token
VITE_AUTH_MODE=local

# SSO 登录入口（sso 模式必填）：完整 URL 或同域路径
# 未登录将整页跳转到此地址，并附带 callbackOrigin/redirect 参数；登录后经 Cookie 回到本站
# 示例：VITE_SSO_LOGIN_URL=http://gateway.giimallai.com/iam/sso/login
VITE_SSO_LOGIN_URL=
