# AI Agent 生产环境变量模板
# 复制为 .env.production 并填写实际值
# 用法: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ============================================
# Docker 镜像与构建
# ============================================
# 国内服务器可配置镜像代理（Docker Hub 拉取加速）
# REGISTRY_PREFIX=docker.m.daocloud.io/

# 后端 base 镜像（首次部署需先执行 ./deploy/deploy.sh --build-base）
# BACKEND_BASE_IMAGE=ai-agent-backend-base:latest

# 国内构建加速（apt、PyPI、npm 镜像）
# 国内服务器建议取消注释；海外服务器可省略
# APT_MIRROR=mirrors.aliyun.com
# UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# NPM_REGISTRY=https://registry.npmmirror.com

# ============================================
# Docker Compose 端口映射
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=80

# ============================================
# Database
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ai_agent

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
