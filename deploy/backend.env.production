# AI Agent Backend 生产环境变量
# 部署时此文件会被复制为 backend/.env
# 数据库和 Redis 地址使用 Docker 内部服务名

# ============================================
# Application
# ============================================
APP_ENV=production
APP_NAME=AI-Agent
DEBUG=false

# ============================================
# Server
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Database (Docker 内部网络)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:ai_agent_prod_2026@db:5432/ai_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ai_agent_prod_2026
POSTGRES_DB=ai_agent

# ============================================
# Redis (Docker 内部网络)
# ============================================
REDIS_URL=redis://:ai_agent_redis_2026@redis:6379/0
REDIS_PASSWORD=ai_agent_redis_2026

# ============================================
# Vector Database (Docker 内部网络)
# ============================================
QDRANT_URL=http://qdrant:6333

# ============================================
# Security
# ============================================
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
COOKIE_SECURE=false

# ============================================
# LLM API Keys
# ============================================
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# 阿里云 DashScope (通义千问 Qwen)
DASHSCOPE_API_KEY=sk-e68cb55642ab4355a672a79a942e95e3
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-6323e770b4b14810a049091037010efe
DEEPSEEK_API_BASE=https://api.deepseek.com

# 火山引擎 (字节豆包)
VOLCENGINE_API_KEY=9d0ef0a2-6465-46cc-b3bd-56b9dd2e4f95
VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_CHAT_ENDPOINT_ID=ep-20260113161350-h8wcx
VOLCENGINE_IMAGE_ENDPOINT_ID=ep-m-20251224180807-6jpr7

# 智谱AI (GLM)
ZHIPUAI_API_KEY=ab842bf9849e4223ac45d8664339a72f.z8fT9H5p0w1XLJrt
ZHIPUAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4

# ============================================
# Storage
# ============================================
WORK_DIR=./workspace
DATA_DIR=./data

# ============================================
# Sandbox
# ============================================
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=300

# ============================================
# Agent
# ============================================
MAX_ITERATIONS=20
DEFAULT_MODEL=deepseek-reasoner

# ============================================
# HITL (Human-in-the-Loop)
# ============================================
HITL_ENABLED=true
HITL_TIMEOUT=300

# ============================================
# Checkpointing
# ============================================
CHECKPOINT_ENABLED=true
CHECKPOINT_INTERVAL=5
CHECKPOINT_TTL=86400

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# OAuth2 Credentials
# ============================================
GIIKIN_CLIENT_ID=2008754197384237056
GIIKIN_CLIENT_SECRET=DDUPPvC9cCBaM1nV-dtrcqiaVejGigF-b5YJ
