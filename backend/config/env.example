# =============================================================================
# AI-Agent 环境变量配置（仅敏感信息）
# =============================================================================
# 使用说明：
# 1. 复制此文件到 backend/.env：cp config/env.example ../.env
# 2. 只需填写敏感信息（API Keys、密码）
# 3. 所有应用逻辑配置在 config/app.toml 中管理
#
# 配置架构：
#   .env           → 敏感信息（API Keys、密码）【本文件】
#   app.toml       → 应用逻辑配置（SimpleMem、Agent 等）
#   Gateway 运行时 api_base → DB 凭据（管理面优先）；默认 URL 见
#   backend/domains/gateway/domain/provider_api_base.py
#
# 模型目录：backend/seeds/gateway-catalog.seed.json
# 模型测试文档：backend/docs/LITELLM_SUPPORTED_MODELS.md
# =============================================================================

# =============================================================================
# 环境设置
# =============================================================================
APP_ENV=development

# =============================================================================
# 安全配置 [必填]
# =============================================================================
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=jwt-secret-change-in-production

# =============================================================================
# 认证模式
#   AUTH_MODE=local   本地/开发：邮箱密码 + JWT 登录（默认）
#   AUTH_MODE=sso     生产：giikin 单点登录（HiGress Header 或 guard_token Cookie + Redis）
#   AUTH_MODE=hybrid  双通道：同时支持 SSO 与邮箱密码登录；Bearer JWT 优先
# =============================================================================
AUTH_MODE=sso
# 与 HiGress giikin-auth-bridge internal_key 对齐（gateway.giimallai.com 测试环境）
GIIKIN_INTERNAL_KEY=mvp-test-internal-key-2026
# 生产保持 false；仅本地调试且未部署 auth-bridge 时可 true（需 IAM Redis，不推荐）
GIIKIN_SESSION_COOKIE_FALLBACK=false
# hybrid 模式下是否允许公开注册（生产建议 false，由管理员创建邮箱账号）
ALLOW_REGISTER=true

# =============================================================================
# 基础设施 [必填]
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agent
REDIS_URL=redis://localhost:6379/0
# 与 giikin-iam 共用 Redis 时必填（见 giikin Nacos spring.data.redis.username）
# REDIS_USERNAME=test_giimall_redis

# =============================================================================
# 向量数据库
# =============================================================================
VECTOR_DB_TYPE=qdrant
QDRANT_URL=http://localhost:6333
# chroma 开发/测试：VECTOR_DB_TYPE=chroma，可选 CHROMA_PATH=./data/chroma

# =============================================================================
# LLM API Keys [至少配置一个]
# =============================================================================
# 支持的提供商与模型目录见 seeds/gateway-catalog.seed.json

# -----------------------------------------------------------------------------
# DeepSeek [推荐首选 - 性价比最高]
# -----------------------------------------------------------------------------
# 官网: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx

# -----------------------------------------------------------------------------
# 阿里云 DashScope (通义千问) [推荐 - 速度最快]
# -----------------------------------------------------------------------------
# 官网: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=sk-xxx

# -----------------------------------------------------------------------------
# 智谱 AI (GLM) [推荐 - 免费额度/超长上下文]
# -----------------------------------------------------------------------------
# 官网: https://open.bigmodel.cn
ZHIPUAI_API_KEY=xxx
# 可选：仅 bootstrap config-managed 凭据时使用；运行时以 DB 凭据 api_base 为准。
# Coding 套餐示例：ZHIPUAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
# 强制用 env 覆盖已有 DB base（慎用）：管理面 system 凭据 extra 设 "force_env_sync": true 后触发 catalog sync

# -----------------------------------------------------------------------------
# 火山引擎 (豆包)
# -----------------------------------------------------------------------------
# 官网: https://console.volcengine.com/ark
# 注意: 需要先在控制台创建端点获取 ENDPOINT_ID
# VOLCENGINE_API_KEY=xxx
# VOLCENGINE_CHAT_ENDPOINT_ID=ep-xxx

# -----------------------------------------------------------------------------
# OpenAI [可选 - Embedding 推荐]
# -----------------------------------------------------------------------------
# 官网: https://platform.openai.com
OPENAI_API_KEY=sk-xxx

# -----------------------------------------------------------------------------
# Anthropic (Claude) [可选]
# -----------------------------------------------------------------------------
# 官网: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxx

# =============================================================================
# 注意：以下配置已移至 config/app.toml
# =============================================================================
# 模型配置、Embedding 配置、Agent 配置等应用逻辑配置
# 请在 config/app.toml 中修改，支持环境特定覆盖：
#   - config/app.development.toml (开发环境)
#   - config/app.production.toml (生产环境)
