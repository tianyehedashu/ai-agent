# Pylint 与 Ruff 分工：重复代码/循环 import、测试访问内部实现、惰性导入、
# Pydantic-SecretStr/SQLAlchemy func 等在此工具链下噪声高，在此关闭；其余规则仍生效。

[FORMAT]
max-module-lines=1300

[DESIGN]
max-branches=20
max-returns=10
max-statements=65
max-public-methods=26

[MESSAGES CONTROL]
disable=
    duplicate-code,
    cyclic-import,
    import-outside-toplevel,
    protected-access,
    broad-exception-caught,
    no-member,
    too-few-public-methods,
    too-many-instance-attributes,
    unused-argument,
    missing-function-docstring,
    missing-class-docstring,
    missing-module-docstring,
    too-many-locals,
    invalid-name,
    global-statement,
    unnecessary-pass,
    no-else-return,
    redefined-outer-name,
    broad-exception-raised,
    wrong-import-position,
    line-too-long,
    wrong-import-order,
    reimported,
    too-many-arguments,
    too-many-positional-arguments,
    unnecessary-ellipsis,
    not-callable,
    no-name-in-module,
    redefined-builtin,
    logging-fstring-interpolation,
    fixme,
    too-many-nested-blocks,
    pointless-statement,
    ungrouped-imports,
