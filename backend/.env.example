# 服务级前缀（默认 /ai-agent；设为空字符串则部署在站点根路径）
ROOT_PATH=/ai-agent

# 场景默认模型（虚拟名，须在 Gateway 可见目录中；空则自动选首个可用）
DEFAULT_MODEL=
FAST_MODEL=
REASONING_MODEL=
CODE_MODEL=
LONG_CONTEXT_MODEL=
VISION_MODEL=

# Embedding（无 EMBEDDING_MODEL 时默认 dashscope/text-embedding-v3）
EMBEDDING_PROVIDER=api
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1024

# Gateway 目录：生产建议 false，用 make seed-gateway 初始化
# 启动期：默认 false。代理调用每次会把上下游单价注入 metadata，DB 价目无需启动全量重注册。
# 写入 DB 上游价时由管理面（PricingService.sync_to_litellm_registry）按 key 增量注册到 LiteLLM。
GATEWAY_CATALOG_SYNC_ON_STARTUP=false
