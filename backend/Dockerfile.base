# AI Agent Backend — Base Image
# 包含 Python 运行时 + uv + git + 系统依赖，在服务器上构建一次后长期复用
# 构建: docker build -f backend/Dockerfile.base -t ai-agent-backend-base:latest ./backend
# 更新时机: Python 版本升级、uv 版本升级、系统依赖变更时重新构建

FROM giimall-acr-registry-vpc.cn-hangzhou.cr.aliyuncs.com/common/python-kubectl:3.11-slim

ARG APT_MIRROR=""
RUN if [ -n "$APT_MIRROR" ]; then \
        sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi \
    && apt-get update \
    && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*

ARG UV_VERSION=0.6.6
ARG UV_INSTALL_METHOD=pip
ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
RUN set -eux; \
    pip install --no-cache-dir "uv==${UV_VERSION}" -i "${PIP_INDEX_URL}"; \
    uv --version


ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

WORKDIR /app
